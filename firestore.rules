rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function isApproved() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('approved', false) == true;
    }

    // 유저 프로필 — 로그인한 모든 사람 읽기 가능, 본인만 쓰기 가능
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if request.auth.uid == uid;
    }

    match /events/{eventId} {
      allow read: if isApproved() &&
        (resource.data.scope == 'team' || resource.data.ownerId == request.auth.uid);
      allow create: if isApproved();
      allow update, delete: if isApproved() && resource.data.ownerId == request.auth.uid;
    }

    match /ideas/{ideaId} {
      allow read, create: if isApproved();
      allow update, delete: if isApproved() && resource.data.ownerId == request.auth.uid;
    }

    match /chat/{msgId} {
      allow read, create: if isApproved();
      allow delete: if isApproved() && resource.data.uid == request.auth.uid;
    }
  }
}
